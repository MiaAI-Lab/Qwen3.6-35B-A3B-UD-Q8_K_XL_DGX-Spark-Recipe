# Optional but recommended for the first model download.
HF_TOKEN=hf_your_read_token_here

# Host Hugging Face cache mounted into the container.
HF_CACHE_DIR=${HOME}/.cache/huggingface

# Host port mapped to llama-server's container port 8888.
PORT=8888

# Leave enabled to download missing GGUF files into the mounted cache.
AUTO_DOWNLOAD=1

# Leave enabled to resolve model files through `hf download` and use the normal
# ~/.cache/huggingface/hub/models--.../snapshots/... cache layout.
USE_HF_DOWNLOAD=1

# Model filenames served by start.sh. If these paths are missing, start.sh uses
# `hf download`, which stores files in the normal Hugging Face hub cache layout.
GGUF_FILE=/root/.cache/huggingface/hub/Qwen3.6-35B-A3B-UD-Q8_K_XL.gguf
MMPROJ_FILE=/root/.cache/huggingface/hub/mmproj-BF16.gguf

# llama.cpp build controls.
# For DGX Spark / GB10, 121 is the default. Change for other GPUs if needed.
CMAKE_CUDA_ARCHITECTURES=121
LLAMA_CPP_REF=master
